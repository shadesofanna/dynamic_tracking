# ============================================
# DEPLOYMENT CONFIGURATION TEMPLATE
# Copy to .env and update with production values
# NEVER commit .env to version control!
# ============================================

# ENVIRONMENT
APP_ENV=production
APP_DEBUG=false
APP_NAME="Dynamic Pricing System"
APP_URL=https://yourdomain.com

# ============================================
# DATABASE
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=dynamic_pricing_db
DB_USER=dbuser
DB_PASSWORD=strong_secure_password_here

# ============================================
# SECURITY
# ============================================
SESSION_LIFETIME=3600
PASSWORD_MIN_LENGTH=8
SECRET_KEY=your_very_long_random_secret_key_here_minimum_32_characters

# ============================================
# EMAIL CONFIGURATION (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=Dynamic Pricing System

# ============================================
# PRICING CONFIGURATION
# ============================================
MIN_PROFIT_MARGIN=0.01
MAX_PRICE_INCREASE=0.05
MAX_PRICE_DECREASE=0.03

# ============================================
# FILE UPLOAD
# ============================================
MAX_FILE_SIZE=5242880
UPLOAD_DIR=/public/assets/images/uploads/

# ============================================
# PAGINATION
# ============================================
PRODUCTS_PER_PAGE=20
ORDERS_PER_PAGE=20

# ============================================
# CURRENCY
# ============================================
DEFAULT_CURRENCY=NGN

# ============================================
# FEATURES
# ============================================
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_SMS_NOTIFICATIONS=false

# ============================================
# API SETTINGS
# ============================================
API_VERSION=v1
API_RATE_LIMIT=100